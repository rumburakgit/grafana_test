{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Order Processing Simulator — monitoring overview",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Order Service",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job='order-service'}[1m])) by (status)",
          "legendFormat": "HTTP {{status}}",
          "refId": "A"
        }
      ],
      "title": "Order Service — Request Rate (req/s)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.10 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job='order-service', status=~'5..'}[2m])) / sum(rate(http_server_requests_seconds_count{job='order-service'}[2m]))",
          "legendFormat": "order-service 5xx rate",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job='inventory-service', status=~'5..'}[2m])) / sum(rate(http_server_requests_seconds_count{job='inventory-service'}[2m]))",
          "legendFormat": "inventory-service 5xx rate",
          "refId": "B"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job='notification-service', status=~'5..'}[2m])) / sum(rate(http_server_requests_seconds_count{job='notification-service'}[2m]))",
          "legendFormat": "notification-service 5xx rate",
          "refId": "C"
        }
      ],
      "title": "Error Rate % — All Services",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(orders_processing_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(orders_processing_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(orders_processing_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ],
      "title": "Order Processing Latency (P50/P95/P99)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "targets": [
        {
          "expr": "sum(rate(orders_total[1m])) by (product_type) * 60",
          "legendFormat": "{{product_type}}",
          "refId": "A"
        }
      ],
      "title": "Orders per Minute by Product Type",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 17 },
      "id": 5,
      "targets": [
        {
          "expr": "orders_pending_count",
          "legendFormat": "Pending Orders",
          "refId": "A"
        }
      ],
      "title": "Orders Pending Count (Queue Depth Simulation)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 17 },
      "id": 6,
      "targets": [
        {
          "expr": "sum(rate(orders_total[1m])) by (status) * 60",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "Orders per Minute by Status (success/failed)",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 101,
      "title": "Inventory Service",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "green", "value": 30 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 24 },
      "id": 7,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "inventory_stock_level",
          "legendFormat": "Stock Level",
          "refId": "A"
        }
      ],
      "title": "Inventory Stock Level",
      "type": "gauge"
    },

    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 24 },
      "id": 8,
      "targets": [
        {
          "expr": "sum(rate(inventory_checks_total[1m])) by (result)",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "title": "Inventory Checks Rate by Result",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 24 },
      "id": 9,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(inventory_response_time_bucket[5m])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(inventory_response_time_bucket[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(inventory_response_time_bucket[5m])) by (le))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ],
      "title": "Inventory Response Time Percentiles",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 102,
      "title": "Notification Service",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "unit": "short",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "id": 10,
      "targets": [
        {
          "expr": "notifications_queue_depth",
          "legendFormat": "Queue Depth",
          "refId": "A"
        }
      ],
      "title": "Notification Queue Depth",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "id": 11,
      "targets": [
        {
          "expr": "sum(rate(notifications_sent_total[1m])) * 60",
          "legendFormat": "Sent / min",
          "refId": "A"
        },
        {
          "expr": "sum(rate(notifications_failed_total[1m])) * 60",
          "legendFormat": "Failed / min",
          "refId": "B"
        }
      ],
      "title": "Notifications Throughput (per minute)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 41 },
      "id": 12,
      "targets": [
        {
          "expr": "notifications_batch_processing_duration_seconds_max",
          "legendFormat": "Max Duration",
          "refId": "A"
        }
      ],
      "title": "Notification Batch Processing Duration",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 47 },
      "id": 103,
      "title": "Infrastructure",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 48 },
      "id": 13,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "background"
      },
      "targets": [
        { "expr": "up{job='order-service'}", "legendFormat": "order-service", "refId": "A" },
        { "expr": "up{job='inventory-service'}", "legendFormat": "inventory-service", "refId": "B" },
        { "expr": "up{job='notification-service'}", "legendFormat": "notification-service", "refId": "C" }
      ],
      "title": "Service Health",
      "type": "stat"
    }

  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["order-processing", "microservices", "demo"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Order Processing Simulator",
  "uid": "order-processing-sim",
  "version": 1
}
