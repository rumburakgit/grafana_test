  "id": null,
  "links": [],
  "panels": [

    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "serviceMap",
          "refId": "A"
        }
      ],
      "title": "Service Map",
      "type": "nodeGraph"
    },

    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "id": 2,
      "options": {
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"order-service\"}[5m])) by (le))",
          "legendFormat": "order-service P95",
          "exemplar": true,
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"inventory-service\"}[5m])) by (le))",
          "legendFormat": "inventory-service P95",
          "exemplar": true,
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"notification-service\"}[5m])) by (le))",
          "legendFormat": "notification-service P95",
          "exemplar": true,
          "refId": "C"
        }
      ],
      "title": "Request Duration P95 (with exemplars — kliknij punkt, aby przejść do trace)",
      "type": "timeseries"
    },

